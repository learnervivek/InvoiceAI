PORT=5000
MONGODB_URI=mongodb://localhost:27017/invoice-generator
JWT_SECRET=your_jwt_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Invoice Generator API (https://invoice-generator.com/developers)
INVOICE_GENERATOR_API_KEY=your_invoice_generator_api_key
INVOICE_API_MONTHLY_LIMIT=100

# Frontend URL
CLIENT_URL=http://localhost:5173

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Notifications
AUTO_SEND_OVERDUE_REMINDERS=false

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
